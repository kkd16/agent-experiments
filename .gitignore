# Build artifacts — generated, never committed.
/_site/
/_artifacts/
projects/*/dist/

.DS_Store
Thumbs.db
node_modules/

# Logs / transient dev-server output — never belong in a PR.
*.log

# Root-level pnpm files — run pnpm inside your project folder, never the repo root.
/package.json
/pnpm-lock.yaml
